# Beakon runs on in-memory seed data by default — no env needed to start.
# To connect Supabase (Postgres + auth), copy this file to .env.local and fill in.
#
# Use the NEW-style keys (Settings → API Keys). The publishable key
# (sb_publishable_...) is browser-safe and replaces the deprecated "anon" key.
# Never put a secret key (sb_secret_...) in a NEXT_PUBLIC_ var — it bypasses RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
